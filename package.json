{
  "name": "myspolly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MYSpolly - a faithful digital implementation of Brass: Birmingham (fan project).",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test --experimental-strip-types \"tests/unit/**/*.test.ts\"",
    "test:engine": "node --test --experimental-strip-types \"tests/unit/**/*.test.ts\"",
    "test:component": "vitest run",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "electron:dev": "pnpm build && electron electron/main.cjs",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "framer-motion": "^11.3.0",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "i18next": "^23.12.0",
    "idb": "^8.0.0",
    "immer": "^10.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.7.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^7.16.0",
    "vite": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "dev.myspolly.app",
    "productName": "MYSpolly",
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" },
    "mac": { "category": "public.app-category.board-games", "target": ["dmg"] },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage", "deb"], "category": "Game" }
  }
}
